# Example environment configuration for Euclid-DESI Cross-Match MCP Server

# Path to Euclid FITS catalog
EUCLID_CATALOG_PATH=/workspaces/euclid-mcp/projects_CSST_shared-data_euclid_aws-mirrors_q1_catalogs_MER_FINAL_CATALOG_102018211_EUC_MER_FINAL-CAT_TILE102018211-CC66F6_20241018T214045.289017Z_00.00.fits

# Path to DESI FITS catalog (sweep file)
# For testing, use the matched test data:
DESI_CATALOG_PATH=/workspaces/euclid-mcp/cross-matching/tests/test_desi_matched.fits

# Matching radius in arcseconds (default: 1.0)
MATCH_RADIUS_ARCSEC=1.0
