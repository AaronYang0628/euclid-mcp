{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "euclid-catalog": {
      "type": "remote",
      "url": "https://catalog.euclid.mcp.ay.dev:32443/sse",
      "enabled": true
    },
    "astro_k3s_mcp": {
      "type": "remote",
      "url": "http://eva24002-entrance.lab.zverse.space:30082/mcp",
      "enabled": false,
      "oauth": false,
      "timeout": 15000
    }
  },
  "provider": {
    "openai": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://v2.qixuw.com/v1",
        "apiKey": "{env:AI_MODEL_KEY}"
      },
      "models": {
        "gpt-5.3-codex": {
          "name": "GPT-5.3 Codex",
          "limit": {
            "context": 400000,
            "output": 128000
          },
          "options": {
            "store": false
          },
          "variants": {
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        }
      }
    }
  },
  "model": "openai/gpt-5.3-codex",
  "small_model": "openai/gpt-5.3-codex",
  "plugin": [],
  "agent": {
    "build": {
      "options": {
        "store": false
      }
    },
    "plan": {
      "options": {
        "store": false
      }
    }
  }
}
